# Flask Configuration
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///solapur_food_share.db
JWT_SECRET_KEY=jwt-secret-string-here

# Twilio Configuration (optional - for SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# OpenAI Configuration (optional - for AI features)
OPENAI_API_KEY=your-openai-api-key

# Email Configuration for Food Donation System
# Gmail SMTP Configuration (Recommended)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Alternative SMTP Providers:
# Outlook/Hotmail:
# MAIL_SERVER=smtp-mail.outlook.com
# MAIL_PORT=587

# Yahoo:
# MAIL_SERVER=smtp.mail.yahoo.com
# MAIL_PORT=587

# SendGrid:
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587

# Note: For Gmail, you need to:
# 1. Enable 2-factor authentication
# 2. Generate an App Password
# 3. Use the App Password as MAIL_PASSWORD
